{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/props",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
        ]
      },
      {
        "source": "/props.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
        ]
      },
      {
        "source": "/props/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20"
    }
  ]
}
